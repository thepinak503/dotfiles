#!/usr/bin/env bash
# Keybind Cheatsheet via YAD – JaKooLit-style hardcoded list

set -euo pipefail

notify() { notify-send -a "Hyprland" -r 9999 "$@"; }

if ! command -v yad &>/dev/null; then
    notify -u critical "Keyhints" "yad is not installed"
    exit 1
fi

killall -q rofi 2>/dev/null || true
killall -q yad 2>/dev/null || true

GDK_BACKEND=wayland yad \
    --center \
    --title="Keybind Cheatsheet" \
    --no-buttons \
    --list \
    --column=Key: \
    --column=Description: \
    --column=Command: \
    --timeout-indicator=bottom \
"ESC / Close" "close this cheat sheet" "" \
"SUPER = " "SUPER KEY (Windows Key)" "(SUPER KEY)" \
"--- Applications ---" " " " " \
"SUPER + Return" "Terminal" "kitty" \
"SUPER + D" "Application launcher" "rofi -show drun" \
"SUPER + Space" "Full app launcher" "rofi (full config)" \
"CTRL + SHIFT + Escape" "System monitor" "kitty btop" \
"SUPER + Tab" "Window switcher" "rofi -show window" \
"SUPER + E" "File manager" "nautilus" \
"SUPER + B" "Browser" "firefox" \
"SUPER + period" "Emoji picker" "rofi -show emoji" \
"--- Window Management ---" " " " " \
"SUPER + Q" "Close active window" "kill" \
"SUPER + Escape" "Power menu" "wlogout" \
"SUPER + F" "Toggle fullscreen" " " \
"SUPER + V" "Toggle floating" " " \
"SUPER + P" "Toggle pseudo layout" " " \
"SUPER + S" "Toggle split direction" "dwindle" \
"SUPER + G" "Toggle window group" " " \
"SUPER + SHIFT + Tab" "Next group window" " " \
"SUPER + CTRL + Tab" "Previous group window" " " \
"SUPER + SHIFT + G" "Toggle lock active group" " " \
"SUPER + CTRL + G" "Move into group forward" " " \
"SUPER + CTRL + SHIFT + G" "Move out of group" " " \
"--- Focus Navigation ---" " " " " \
"SUPER + Left" "Focus window left" " " \
"SUPER + Right" "Focus window right" " " \
"SUPER + K" "Focus window up" " " \
"SUPER + J" "Focus window down" " " \
"--- Move / Swap / Resize ---" " " " " \
"SUPER + ALT + H" "Move window left" " " \
"SUPER + ALT + L" "Move window right" " " \
"SUPER + ALT + K" "Move window up" " " \
"SUPER + ALT + J" "Move window down" " " \
"SUPER + ALT + SHIFT + H" "Swap window left" " " \
"SUPER + ALT + SHIFT + L" "Swap window right" " " \
"SUPER + ALT + SHIFT + K" "Swap window up" " " \
"SUPER + ALT + SHIFT + J" "Swap window down" " " \
"SUPER + SHIFT + H" "Resize window left" " " \
"SUPER + SHIFT + L" "Resize window right" " " \
"SUPER + SHIFT + K" "Resize window up" " " \
"SUPER + SHIFT + J" "Resize window down" " " \
"SUPER + LMB drag" "Move window (mouse)" " " \
"SUPER + SHIFT + LMB drag" "Resize window (mouse)" " " \
"--- Workspaces ---" " " " " \
"SUPER + 1-9" "Switch to workspace N" " " \
"SUPER + SHIFT + 1-9" "Move window to workspace N" " " \
"SUPER + scroll down/up" "Next / previous workspace" " " \
"SUPER + SHIFT + Right/Left" "Focus next / prev monitor" " " \
"SUPER + CTRL + Right/Left" "Next / previous global ws" " " \
"SUPER + SHIFT + ]/[" "Move window to next / prev ws" " " \
"SUPER + \`" "Toggle scratchpad" " " \
"SUPER + SHIFT + \`" "Move window to scratchpad" " " \
"--- Screenshots & Recording ---" " " " " \
"Print" "Screenshot (full)" "hyprshot" \
"SHIFT + Print" "Screenshot (area)" "hyprshot" \
"CTRL + Print" "Screenshot (window)" "hyprshot" \
"SUPER + SHIFT + S" "Screenshot (area)" "hyprshot" \
"SUPER + CTRL + S" "Region to Swappy editor" "hyprshot" \
"SUPER + CTRL + SHIFT + S" "Screenshot menu" " " \
"SUPER + SHIFT + Print" "Active window screenshot" "hyprshot" \
"--- System ---" " " " " \
"SUPER + L" "Lock screen" "hyprlock" \
"SUPER + CTRL + Q" "Exit Hyprland" "hyprctl" \
"SUPER + CTRL + L" "Change layout (master/dwindle)" " " \
"SUPER + SHIFT + R" "Reload config" "hyprctl reload" \
"SUPER + SHIFT + M" "Game mode toggle" " " \
"SUPER + SHIFT + A" "Animations menu" "rofi" \
"SUPER + T" "Toggle touchpad" " " \
"SUPER + SHIFT + C" "Color picker" "hyprpicker" \
"SUPER + SHIFT + N" "Toggle notifications" "swaync" \
"SUPER + SHIFT + B" "Toggle waybar" "" \
"SUPER + CTRL + B" "Reload waybar" "" \
"SUPER + SHIFT + D" "Diagnostic report" "kitty" \
"SUPER + SHIFT + V" "Clipboard manager" "cliphist" \
"SUPER + SHIFT + T" "Light theme" " " \
"SUPER + CTRL + SHIFT + T" "Dark theme" " " \
"SUPER + SHIFT + W" "Next wallpaper" " " \
"SUPER + W" "Random wallpaper" " " \
"--- Settings ---" " " " " \
"SUPER + SHIFT + E" "Quick settings menu" "rofi" \
"SUPER + ALT + R" "Refresh all UI" " " \
"SUPER + ALT + O" "Toggle blur" " " \
"SUPER + N" "Toggle night light" "hyprsunset" \
"SUPER + H" "Keybind cheatsheet" "yad" \
"SUPER + /" "Search keybinds" "rofi" \
"SUPER + SHIFT + D" "Diagnose + reload" "diagreload" \
"--- Media Keys ---" " " " " \
"XF86AudioRaiseVolume" "Volume up" " " \
"XF86AudioLowerVolume" "Volume down" " " \
"XF86AudioMute" "Mute / unmute" " " \
"XF86MonBrightnessUp" "Brightness up" " " \
"XF86MonBrightnessDown" "Brightness down" " " \
"XF86AudioPlay" "Play / pause" "playerctl" \
"XF86AudioNext" "Next track" "playerctl" \
"XF86AudioPrev" "Previous track" "playerctl"

#!/bin/bash
set -euo pipefail

notify() { notify-send -a "Hyprland" -r 9999 "$@"; }

CONFIG_DIR="$HOME/.local/share/dotfiles/hypr/configs"
SCRIPTS_DIR="$HOME/.local/share/dotfiles/hypr/scripts"

if ! command -v rofi &>/dev/null; then
    notify -u critical "Settings" "rofi is not installed"
    exit 1
fi

CHOICE=$(printf \
"ď€“ Edit Keybinds\nď€“ Edit Window Rules\nď€“ Edit Decorations\nď€“ Edit Animations\nď€“ Edit Autostart\nď…› Choose Animation Profile\nď‡Ľ Choose Rofi Theme\nď‰© Choose Kitty Theme\nî…Ł Toggle Blur\nî…Ł Toggle Night Light\nó°„• Toggle Game Mode\nî«† Refresh All" \
| rofi -dmenu -p "Settings" -i)

[[ -z "$CHOICE" ]] && exit 0

case "$CHOICE" in
    "ď€“ Edit Keybinds")
        [[ -f "$CONFIG_DIR/keybinds.lua" ]] || { notify -u critical "Settings" "keybinds.lua not found"; exit 1; }
        kitty -e nano "$CONFIG_DIR/keybinds.lua" ;;
    "ď€“ Edit Window Rules")
        [[ -f "$CONFIG_DIR/windowrules.lua" ]] || { notify -u critical "Settings" "windowrules.lua not found"; exit 1; }
        kitty -e nano "$CONFIG_DIR/windowrules.lua" ;;
    "ď€“ Edit Decorations")
        [[ -f "$CONFIG_DIR/decor.lua" ]] || { notify -u critical "Settings" "decor.lua not found"; exit 1; }
        kitty -e nano "$CONFIG_DIR/decor.lua" ;;
    "ď€“ Edit Animations")
        [[ -f "$CONFIG_DIR/animations.lua" ]] || { notify -u critical "Settings" "animations.lua not found"; exit 1; }
        kitty -e nano "$CONFIG_DIR/animations.lua" ;;
    "ď€“ Edit Autostart")
        [[ -f "$CONFIG_DIR/autostart.lua" ]] || { notify -u critical "Settings" "autostart.lua not found"; exit 1; }
        kitty -e nano "$CONFIG_DIR/autostart.lua" ;;
    "ď…› Choose Animation Profile")
        [[ -x "$SCRIPTS_DIR/animations-menu" ]] || { notify -u critical "Settings" "animations-menu not found"; exit 1; }
        "$SCRIPTS_DIR/animations-menu" ;;
    "ď‡Ľ Choose Rofi Theme")
        notify -u low "Settings" "Rofi theme selector not available" ;;
    "ď‰© Choose Kitty Theme")
        notify -u low "Settings" "Kitty theme selector not available" ;;
    "î…Ł Toggle Blur")
        [[ -x "$SCRIPTS_DIR/blur-toggle" ]] || { notify -u critical "Settings" "blur-toggle not found"; exit 1; }
        "$SCRIPTS_DIR/blur-toggle" ;;
    "î…Ł Toggle Night Light")
        [[ -x "$SCRIPTS_DIR/nightlight" ]] || { notify -u critical "Settings" "nightlight not found"; exit 1; }
        "$SCRIPTS_DIR/nightlight" ;;
    "ó°„• Toggle Game Mode")
        [[ -x "$SCRIPTS_DIR/gamemode" ]] || { notify -u critical "Settings" "gamemode not found"; exit 1; }
        "$SCRIPTS_DIR/gamemode" ;;
    "î«† Refresh All")
        [[ -x "$SCRIPTS_DIR/refresh" ]] || { notify -u critical "Settings" "refresh not found"; exit 1; }
        "$SCRIPTS_DIR/refresh" ;;
    *)
        notify -u low "Settings" "No valid option selected"
        exit 1 ;;
esac

#!/bin/bash
set -euo pipefail

notify() { notify-send -a "Hyprland" -r 9999 "$@"; }

if ! command -v hyprctl &>/dev/null; then
    notify -u critical "Layout" "hyprctl not available"
    exit 1
fi

LAYOUT=$(hyprctl -j getoption general:layout | jq -r '.str') || true

case $LAYOUT in
  master)
    hyprctl keyword general:layout dwindle 2>/dev/null || true
    hyprctl keyword unbind SUPER,J 2>/dev/null || true
    hyprctl keyword unbind SUPER,K 2>/dev/null || true
    hyprctl keyword bind SUPER,J,layoutmsg,cyclenext 2>/dev/null || true
    hyprctl keyword bind SUPER,K,layoutmsg,cycleprev 2>/dev/null || true
    notify -u low "Dwindle Layout"
    ;;
  dwindle)
    hyprctl keyword general:layout master 2>/dev/null || true
    hyprctl keyword unbind SUPER,J 2>/dev/null || true
    hyprctl keyword unbind SUPER,K 2>/dev/null || true
    hyprctl keyword unbind SUPER,O 2>/dev/null || true
    hyprctl keyword bind SUPER,J,cyclenext 2>/dev/null || true
    hyprctl keyword bind SUPER,K,cycleprev,prev 2>/dev/null || true
    notify -u low "Master Layout"
    ;;
  *)
    notify -u critical "Layout" "Unknown layout: $LAYOUT"
    exit 1
    ;;
esac

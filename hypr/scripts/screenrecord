#!/usr/bin/env bash
# ============================================================================
# Screen Recording — record screen/region/window via wf-recorder
# ============================================================================
# Supports: full screen, region, window, audio, pause/resume, format select
# ============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
RECORDING_DIR="${RECORDING_DIR:-$HOME/Videos/Recordings}"
mkdir -p "$RECORDING_DIR"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
PID_FILE="/tmp/hypr-recording.pid"
STATE_FILE="/tmp/hypr-recording-state"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
notify() { notify-send -a "Hyprland" -r 9999 "$@"; }

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [args]

Commands:
  --full           Record full screen with audio
  --region         Record selected region with audio
  --window         Record selected window
  --no-audio       Record full screen without audio
  --region-only    Record region without audio
  --stop           Stop active recording
  --toggle         Toggle recording on/off (full screen with audio)
  --pause          Pause active recording (if supported)
  --mp4            Record in MP4 format
  --mkv            Record in MKV format
  --webm           Record in WebM format
  --gif            Record as GIF (lossy)
  --fps <n>        Record at specific FPS (default 30)
  --status         Show recording status

EOF
    exit 1
}

# ---------------------------------------------------------------------------
# Recording control
# ---------------------------------------------------------------------------
is_recording() {
    [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null
}

record() {
    local mode="${1:-full}"
    local audio="${2:-yes}"
    local format="${3:-mp4}"
    local fps="${4:-30}"
    local extra_args=""

    if is_recording; then
        notify -u low "Recording" "Already recording! Use --stop to end."
        exit 0
    fi

    local extension="$format"
    [[ "$format" == "gif" ]] && extension="gif"

    local outfile="$RECORDING_DIR/recording_${TIMESTAMP}.${extension}"
    local cmd_args=()

    # Region selection
    if [[ "$mode" == "region" ]] || [[ "$mode" == "region-only" ]]; then
        notify -u low "Recording" "Select a region to record..."
        local region
        region=$(slurp 2>/dev/null) || {
            notify -u critical "Recording" "No region selected"
            exit 1
        }
        cmd_args+=(-g "$region")
    elif [[ "$mode" == "window" ]]; then
        notify -u low "Recording" "Click a window to record..."
        local geometry
        geometry=$(hyprctl activewindow -j 2>/dev/null | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"' 2>/dev/null) || {
            notify -u critical "Recording" "Could not detect active window"
            exit 1
        }
        cmd_args+=(-g "$geometry")
    fi

    # Audio
    if [[ "$audio" == "yes" ]]; then
        cmd_args+=(-a)
    fi

    # Format-specific options
    if [[ "$format" == "mkv" ]]; then
        cmd_args+=(-c h264_vaapi)
    elif [[ "$format" == "gif" ]]; then
        cmd_args+=(-c gif)
    fi

    # FPS
    cmd_args+=(-r "$fps")

    # Output file
    cmd_args+=(-f "$outfile")

    # Start recording
    wf-recorder "${cmd_args[@]}" &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    echo "recording" > "$STATE_FILE"

    notify -u low -i media-record "Recording" "Started ($mode, $fps fps, $format)"
}

stop_recording() {
    if is_recording; then
        local pid
        pid=$(cat "$PID_FILE" 2>/dev/null || echo "")
        if [[ -n "$pid" ]]; then
            kill "$pid" 2>/dev/null || true
            sleep 0.5
        fi
        killall -q wf-recorder 2>/dev/null || true
        rm -f "$PID_FILE"
        echo "stopped" > "$STATE_FILE"
        notify -u low -i media-record "Recording" "Stopped — saved to $RECORDING_DIR/"
    else
        notify -u low "Recording" "No active recording found"
    fi
}

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
if ! command -v wf-recorder &>/dev/null; then
    notify -u critical "Screen Recording" "wf-recorder is not installed"
    exit 1
fi

# ---------------------------------------------------------------------------
# Main logic
# ---------------------------------------------------------------------------
case "${1:-}" in
    --full)
        local fps="${2:-30}"
        record "full" "yes" "mp4" "$fps"
        ;;

    --region)
        local fps="${2:-30}"
        record "region" "yes" "mp4" "$fps"
        ;;

    --window)
        local fps="${2:-30}"
        record "window" "yes" "mp4" "$fps"
        ;;

    --no-audio)
        local fps="${2:-30}"
        record "full" "no" "mp4" "$fps"
        ;;

    --region-only)
        local fps="${2:-30}"
        record "region-only" "no" "mp4" "$fps"
        ;;

    --stop)
        stop_recording
        ;;

    --toggle)
        if is_recording; then
            stop_recording
        else
            record "full" "yes" "mp4" 30
        fi
        ;;

    --pause)
        if is_recording; then
            kill -SIGSTOP "$(cat "$PID_FILE")" 2>/dev/null || true
            echo "paused" > "$STATE_FILE"
            notify -u low "Recording" "Paused"
        else
            notify -u low "Recording" "No active recording to pause"
        fi
        ;;

    --mp4)
        record "full" "yes" "mp4" 30
        ;;

    --mkv)
        record "full" "yes" "mkv" 30
        ;;

    --webm)
        record "full" "yes" "webm" 30
        ;;

    --gif)
        record "full" "no" "gif" 15
        ;;

    --fps)
        local fps="${2:-30}"
        record "full" "yes" "mp4" "$fps"
        ;;

    --status)
        if is_recording; then
            local state
            state=$(cat "$STATE_FILE" 2>/dev/null || echo "recording")
            echo "Recording: $state (PID: $(cat "$PID_FILE" 2>/dev/null || echo 'unknown'))"
        else
            echo "Recording: not active"
        fi
        ;;

    --help|-h)
        usage
        ;;

    "")
        if is_recording; then
            stop_recording
        else
            record "full" "yes" "mp4" 30
        fi
        ;;

    *)
        usage
        ;;
esac

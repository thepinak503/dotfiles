#!/bin/bash

set -euo pipefail

GPU_DETECT="${HOME}/.local/share/dotfiles/hypr/scripts/gpu-detect"

if [[ ! -x "$GPU_DETECT" ]]; then
  echo "gpu-detect not found at $GPU_DETECT" >&2
  exit 1
fi

GPU_JSON=$("$GPU_DETECT" 2>/dev/null) || {
  echo "gpu-detect failed" >&2
  exit 1
}

TMP_ENV="/tmp/hypr-gpu-env.sh"
HYPR_ENV_LUA="${HOME}/.local/share/dotfiles/hypr/configs/env.lua"

# Generate shell env file
python3 -c "
import sys, json
d = json.load(sys.stdin)
e = d.get('hyprland_env', {})
lines = []
for k, v in e.items():
    lines.append(f'export {k}={v}')
sys.stdout.write('\n'.join(lines))
" <<< "$GPU_JSON" 2>/dev/null | while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  var_name="${line#export }"
  var_name="${var_name%%=*}"
  # Don't overwrite user-set env vars
  if [[ -z "${!var_name:-}" ]]; then
    echo "$line"
  fi
done > "$TMP_ENV" 2>/dev/null || true
chmod 644 "$TMP_ENV" 2>/dev/null || true

# Generate Hyprland Lua env config
python3 -c "
import sys, json
d = json.load(sys.stdin)
e = d.get('hyprland_env', {})
lines = ['-- Auto-generated GPU environment (DO NOT EDIT MANUALLY)',
         '-- Generated by set-env script']
for k, v in e.items():
    lines.append(f'hl.env(\"{k}\", \"{v}\")')
# Also handle deprecation warnings gracefully
if d.get('has_nvidia', False):
    lines.append('')
    lines.append('-- NVIDIA-specific: only set if not already configured')
    lines.append('if not hl.env(\"WLR_NO_HARDWARE_CURSORS\") then')
    lines.append('    -- WLR_NO_HARDWARE_CURSORS is deprecated on Hyprland 0.45+')
    lines.append('end')
sys.stdout.write('\n'.join(lines))
" <<< "$GPU_JSON" > "$HYPR_ENV_LUA" 2>/dev/null || true

echo "GPU env written to $TMP_ENV and $HYPR_ENV_LUA" >&2

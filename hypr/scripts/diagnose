#!/bin/bash
# Hyprland Desktop Environment Diagnostic Script
# Tests all components and reports issues

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

PASS=0
FAIL=0
WARN=0

DOTFILES="$HOME/.local/share/dotfiles"
HYPR_CONFIG="$HOME/.config/hypr"
WAYBAR_CONFIG="$HOME/.config/waybar"
ROFI_CONFIG="$HOME/.config/rofi"

pass() { PASS=$((PASS+1)); echo -e "  ${GREEN}✓${NC} $1"; }
fail() { FAIL=$((FAIL+1)); echo -e "  ${RED}✗${NC} $1"; }
warn() { WARN=$((WARN+1)); echo -e "  ${YELLOW}⚠${NC} $1"; }
skip() { echo -e "  ${BLUE}-${NC} $1"; }

check_cmd() {
    if command -v "$1" &>/dev/null; then pass "$2"; else fail "$2"; fi
}

section() {
    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  $1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

subsection() {
    echo -e "\n${YELLOW}  $1${NC}"
}

# ═══════════════════════════════════════════════════════════
# 1. SYSTEM INFO
# ═══════════════════════════════════════════════════════════
section "System Information"
echo "  Host: $(hostname)"
echo "  User: $USER"
echo "  Kernel: $(uname -r)"
echo "  Desktop: ${XDG_CURRENT_DESKTOP:-unknown}"
echo "  Session: ${XDG_SESSION_TYPE:-unknown}"
echo "  Distro: $(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME" || echo "unknown")"

# ═══════════════════════════════════════════════════════════
# 2. HYPRLAND
# ═══════════════════════════════════════════════════════════
section "Hyprland"

subsection "Core"
check_cmd hyprctl "hyprctl binary"

if command -v hyprctl &>/dev/null; then
    HV=$(hyprctl version 2>/dev/null | head -1 | grep -oP 'Hyprland \K[\d.]+' || echo "unknown")
    echo "  Version: ${HV:-unknown}"

    ERRORS=$(hyprctl configerrors 2>/dev/null | tr -d '\n')
    if [[ -z "$ERRORS" ]]; then
        pass "Config errors: none"
    else
        fail "Config errors: $ERRORS"
    fi

    INSTANCE=$(hyprctl instances 2>/dev/null | head -1 | awk '{print $2}')
    if [[ -n "$INSTANCE" ]]; then
        pass "Instance running (PID: $INSTANCE)"
    else
        fail "No Hyprland instance detected"
    fi

    BINDS=$(hyprctl binds 2>/dev/null | grep -c "dispatcher" || echo "0")
    LUA_BINDS=$(hyprctl binds 2>/dev/null | grep -c "__lua" || echo "0")
    echo "  Total binds: $BINDS (Lua: $LUA_BINDS)"
    if [[ "$BINDS" -gt 0 ]]; then pass "Keybinds loaded"; else fail "No keybinds loaded"; fi

    MONITOR_COUNT=$(hyprctl monitors 2>/dev/null | grep -c "Monitor" || echo "0")
    echo "  Monitors: $MONITOR_COUNT"
    hyprctl monitors 2>/dev/null | grep -oP 'Monitor \K\S+|described.*?\K\d+x\d+' | paste - - | while read -r name res; do
        echo "    $name → $res"
    done
fi

subsection "Config Files"
CONFIG_FILES=(
    "$HYPR_CONFIG/hyprland.lua"
    "$HYPR_CONFIG/configs/keybinds.lua"
    "$HYPR_CONFIG/configs/autostart.lua"
    "$HYPR_CONFIG/configs/monitors.lua"
    "$HYPR_CONFIG/configs/input.lua"
    "$HYPR_CONFIG/configs/decor.lua"
    "$HYPR_CONFIG/configs/animations.lua"
    "$HYPR_CONFIG/configs/windowrules.lua"
    "$HYPR_CONFIG/configs/workspaces.lua"
    "$HYPR_CONFIG/configs/theme.lua"
    "$HYPR_CONFIG/configs/devices.lua"
)
for F in "${CONFIG_FILES[@]}"; do
    if [[ -f "$F" ]]; then pass "Config exists: ${F#$HYPR_CONFIG/}"; else fail "Missing: ${F#$HYPR_CONFIG/}"; fi
done

# Check for stub conf that overrides Lua config
if [[ -f "$HYPR_CONFIG/hyprland.conf" && ! -L "$HYPR_CONFIG/hyprland.conf" ]]; then
    fail "Stub hyprland.conf exists — overrides Lua config!"
else
    pass "No stub hyprland.conf interfering"
fi

# ═══════════════════════════════════════════════════════════
# 3. GPU / ENVIRONMENT
# ═══════════════════════════════════════════════════════════
section "GPU & Environment"

subsection "GPU Detection"
if [[ -f "$DOTFILES/hypr/scripts/gpu-detect" ]]; then
    GPU_OUTPUT=$("$DOTFILES/hypr/scripts/gpu-detect" 2>/dev/null || echo "error")
    echo "  $GPU_OUTPUT"
fi

if [[ -f "$HYPR_CONFIG/configs/env.lua" ]]; then
    pass "env.lua generated by set-env"
    echo "  Contents:"
    grep "AQ_DRM\|GBM\|LIBVA\|VDPAU\|XDG_CURRENT_DESKTOP" "$HYPR_CONFIG/configs/env.lua" 2>/dev/null | 
        sed 's/^/    /'
else
    warn "env.lua not found (will be generated on next start)"
fi

subsection "Key Environment Variables"
for VAR in XDG_CURRENT_DESKTOP XDG_SESSION_TYPE WAYLAND_DISPLAY AQ_DRM_DEVICES; do
    VAL=${!VAR:-}
    if [[ -n "$VAL" ]]; then pass "$VAR=$VAL"; else warn "$VAR not set"; fi
done

# ═══════════════════════════════════════════════════════════
# 4. KEYBIND SCRIPTS
# ═══════════════════════════════════════════════════════════
section "Custom Scripts"

SCRIPT_DIR="$DOTFILES/hypr/scripts"
SCRIPTS=(
    "keyhints-yad" "settings-menu" "screenshot" "refresh" "blur-toggle"
    "nightlight" "animations-menu" "gpu-detect" "set-env" "changeLayout"
    "touchpad" "gamemode" "wallpaper-fetch" "transparency"
)
for S in "${SCRIPTS[@]}"; do
    F="$SCRIPT_DIR/$S"
    if [[ -f "$F" ]]; then
        if [[ -x "$F" ]]; then
            SYNTAX_OK=$(bash -n "$F" 2>&1 || echo "SYNTAX ERROR")
            if [[ "$SYNTAX_OK" == "SYNTAX ERROR" ]]; then
                fail "Script syntax error: $S ($(bash -n "$F" 2>&1))"
            else
                pass "Script OK: $S"
            fi
        else
            warn "Script not executable: $S"
        fi
    else
        fail "Script missing: $S"
    fi
done

ANIM_DIR="$DOTFILES/hypr/animations"
for P in default fast smooth; do
    if [[ -f "$ANIM_DIR/$P.lua" ]]; then pass "Animation profile: $P"; else fail "Animation profile missing: $P"; fi
done

# ═══════════════════════════════════════════════════════════
# 5. WAYBAR
# ═══════════════════════════════════════════════════════════
section "Waybar"

subsection "Processes"
WAYBAR_COUNT=$(pgrep -x waybar 2>/dev/null | wc -l)
echo "  Running instances: $WAYBAR_COUNT"
if [[ "$WAYBAR_COUNT" -ge 1 ]]; then pass "Waybar running"; else fail "Waybar not running"; fi

subsection "Config Validation"
for CFG in config.jsonc config-bottom.jsonc; do
    F="$DOTFILES/waybar/$CFG"
    if [[ -f "$F" ]]; then
        python3 -c "
import json, re, sys
with open('$F') as f:
    stripped = re.sub(r'//.*$', '', f.read(), flags=re.MULTILINE)
try:
    json.loads(stripped)
    sys.exit(0)
except json.JSONDecodeError as e:
    print(e)
    sys.exit(1)
" 2>/dev/null && pass "Waybar config valid: $CFG" || fail "Waybar config INVALID: $CFG"
    else
        fail "Waybar config missing: $CFG"
    fi
done

# ═══════════════════════════════════════════════════════════
# 6. ROFI
# ═══════════════════════════════════════════════════════════
section "Rofi"

RV=$(rofi -version 2>/dev/null | grep -oP '\d+\.\d+\.\d+' || echo "not found")
echo "  Version: $RV"

if command -v rofi &>/dev/null; then
    if [[ -f "$ROFI_CONFIG/config.rasi" ]]; then
        pass "Config exists"
        if rofi -dump-config &>/dev/null; then
            pass "Config loads correctly"
        else
            fail "Config fails to load"
        fi
    else
        fail "Config missing"
    fi
    if [[ -f "$ROFI_CONFIG/themes/nord.rasi" ]]; then
        pass "Nord theme exists"
        if rofi -dump-theme &>/dev/null; then
            pass "Theme loads correctly"
        else
            fail "Theme fails to load"
        fi
    else
        fail "Nord theme missing"
    fi
fi

# ═══════════════════════════════════════════════════════════
# 7. YAD / NOTIFICATIONS
# ═══════════════════════════════════════════════════════════
section "YAD & Notifications"

check_cmd yad "YAD installed"

if command -v yad &>/dev/null; then
    if [[ -f "$SCRIPT_DIR/keyhints-yad" ]]; then
        ARGS=$(bash -n "$SCRIPT_DIR/keyhints-yad" 2>&1)
        if [[ -z "$ARGS" ]]; then
            pass "YAD keyhints script syntax OK"
        else
            fail "YAD keyhints syntax: $ARGS"
        fi
        # Count data rows (3 values per row)
        ROWS=$(bash -x "$SCRIPT_DIR/keyhints-yad" 2>&1 | grep -o "''\|'[^']*'" | wc -l)
        DATA_VALS=$((ROWS - 8))  # subtract yad options
        if (( DATA_VALS > 0 && DATA_VALS % 3 == 0 )); then
            pass "YAD data: $((DATA_VALS / 3)) rows × 3 columns"
        else
            warn "YAD data alignment: $DATA_VALS values (not divisible by 3)"
        fi
    fi
fi

check_cmd swaync "swaync installed"
if command -v swaync-client &>/dev/null; then
    SWAYNC_OK=$(swaync-client --swaync-command 'get-dnd' 2>/dev/null && echo "OK" || echo "no")
    if [[ "$SWAYNC_OK" == "OK" ]]; then pass "Swaync responding"; else warn "Swaync not responding"; fi
fi

check_cmd notify-send "notify-send available"

# ═══════════════════════════════════════════════════════════
# 8. SERVICES
# ═══════════════════════════════════════════════════════════
section "Background Services"

SERVICES=(
    "hypridle:Hyprland idle daemon"
    "hyprlock:Screen locker"
    "hyprsunset:Night light"
    "swaync:Notification daemon"
    "swayosd-server:OSD server"
    "nm-applet:Network manager applet"
    "blueman-applet:Bluetooth applet"
    "polkit-gnome-authentication-agent-1:PolKit agent"
)
for S in "${SERVICES[@]}"; do
    NAME="${S%%:*}"
    DESC="${S##*:}"
    if pgrep -x "$NAME" &>/dev/null || pgrep -f "$NAME" &>/dev/null; then
        pass "$DESC running"
    else
        warn "$DESC not running"
    fi
done

# ═══════════════════════════════════════════════════════════
# 9. WALLPAPERS
# ═══════════════════════════════════════════════════════════
section "Wallpapers"

if pgrep -x hyprpaper &>/dev/null; then
    pass "Hyprpaper running"
else
    warn "Hyprpaper not running"
fi

if [[ -f "$DOTFILES/hypr/scripts/wallpaper-fetch" ]]; then
    if [[ -x "$DOTFILES/hypr/scripts/wallpaper-fetch" ]]; then
        pass "Wallpaper-fetch script exists"
    else
        warn "wallpaper-fetch not executable"
    fi
fi

# ═══════════════════════════════════════════════════════════
# 10. NETWORK / SOUND
# ═══════════════════════════════════════════════════════════
section "Hardware"

check_cmd pactl "PulseAudio pactl"
if command -v pactl &>/dev/null; then
    SINKS=$(pactl list sinks short 2>/dev/null | wc -l)
    echo "  Audio sinks: $SINKS"
fi

check_cmd playerctl "playerctl (media keys)"
check_cmd brightnessctl "brightnessctl"
check_cmd nmcli "nmcli (network)"

# ═══════════════════════════════════════════════════════════
# 11. THEME
# ═══════════════════════════════════════════════════════════
section "Theme System"

if [[ -f "$DOTFILES/themes/theme.sh" ]]; then
    pass "Theme script exists"
    if [[ -x "$DOTFILES/themes/theme.sh" ]]; then pass "Theme script executable"; else warn "Theme script not executable"; fi
    MODE=$("$DOTFILES/themes/theme.sh" 2>/dev/null | head -1 || echo "unknown")
    echo "  Current theme mode: $MODE"
else
    fail "Theme script missing"
fi

# ═══════════════════════════════════════════════════════════
# 12. WLOGOUT
# ═══════════════════════════════════════════════════════════
section "Wlogout"
check_cmd wlogout "wlogout installed"
if [[ -d "$DOTFILES/wlogout" ]]; then pass "Wlogout layout exists"; else fail "Wlogout layout missing"; fi

# ═══════════════════════════════════════════════════════════
# 13. DOTFILES SYMLINKS
# ═══════════════════════════════════════════════════════════
section "Dotfiles Symlinks"

SYMLINKS=(
    "$HYPR_CONFIG/hyprland.lua"
    "$HYPR_CONFIG/configs"
    "$WAYBAR_CONFIG/style.css"
)
for S in "${SYMLINKS[@]}"; do
    if [[ -L "$S" ]]; then
        TARGET=$(readlink "$S")
        if [[ "$TARGET" == "$DOTFILES"* ]]; then
            pass "Symlink OK: ${S#$HOME/} → ${TARGET#$DOTFILES/}"
        else
            warn "Symlink points outside dotfiles: ${S#$HOME/} → $TARGET"
        fi
    elif [[ -f "$S" ]] || [[ -d "$S" ]]; then
        warn "Not a symlink: ${S#$HOME/} (copy, not linked to dotfiles)"
    else
        fail "Missing: ${S#$HOME/}"
    fi
done

# ═══════════════════════════════════════════════════════════
# SUMMARY
# ═══════════════════════════════════════════════════════════
section "Results"
echo -e "  ${GREEN}Passed: $PASS${NC}"
echo -e "  ${RED}Failed: $FAIL${NC}"
echo -e "  ${YELLOW}Warnings: $WARN${NC}"

if [[ "$FAIL" -eq 0 ]]; then
    echo -e "\n  ${GREEN}✅ All critical checks passed!${NC}"
else
    echo -e "\n  ${RED}❌ $FAIL failures found — review above.${NC}"
fi

exit "$FAIL"

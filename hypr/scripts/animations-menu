#!/bin/bash
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.local/share/dotfiles}"

notify() { notify-send -a "Hyprland" -r 9999 "$@"; }

ANIM_DIR="$DOTFILES_DIR/hypr/animations"
CONFIG_DIR="$DOTFILES_DIR/hypr/configs"

if ! command -v rofi &>/dev/null; then
    notify -u critical "Animation Profiles" "rofi is not installed"
    exit 1
fi

if ! command -v hyprctl &>/dev/null; then
    notify -u critical "Animation Profiles" "hyprctl not available"
    exit 1
fi

# Find animation profiles safely using find (avoids SC2011: ls parsing)
PROFILES=$(find "$ANIM_DIR" -maxdepth 1 -name '*.lua' -exec basename {} .lua \; 2>/dev/null | sort)

if [[ -z "$PROFILES" ]]; then
    notify -u critical "Animation Profiles" "No profiles found in $ANIM_DIR"
    exit 1
fi

CHOICE=$(echo "$PROFILES" | rofi -dmenu -p "Animation Profile" -i)

if [[ -z "$CHOICE" ]]; then
    exit 0
fi

PROFILE_FILE="$ANIM_DIR/$CHOICE.lua"
if [[ -f "$PROFILE_FILE" ]]; then
    cp "$PROFILE_FILE" "$CONFIG_DIR/animations.lua"
    hyprctl reload 2>/dev/null || true
    notify -u low "Animation Profile" "Switched to: $CHOICE"
else
    notify -u critical "Animation Profiles" "Profile '$CHOICE' not found"
    exit 1
fi

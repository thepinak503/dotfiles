# Nano Editor Configuration - Comprehensive Setup
# Simple and user-friendly terminal-based text editor

# =============================================================================
# BEHAVIOR
# =============================================================================

# Enable mouse support
set mouse

# Enable auto-indentation
set autoindent

# Show line numbers
set linenumbers

# Constantly show cursor position
set constantshow

# Convert tabs to spaces
set tabstospaces

# Tab size
set tabsize 4

# Enable word wrapping (default)
set nowrap

# Hard wrap at 80 characters
set fill 80

# Enable soft wrap indicator
set softwrap

# Enable quick blank
set quickblank

# Show guide stripe at 80 columns
set guidestripe 80

# =============================================================================
# BACKUP & HISTORY
# =============================================================================

# Enable backups
set backup

# Backup directory
set backupdir "/home/pinak/.nano/backups"

# History log
set historylog

# Position log (remember cursor position)
set positionlog

# =============================================================================
# SYNTAX HIGHLIGHTING
# =============================================================================

# Enable syntax highlighting
include "/usr/share/nano/*.nanorc"

# =============================================================================
# INTERFACE
# =============================================================================

# Enable bold text
set boldtext

# Enable title bar color (brightwhite on blue)
set titlecolor brightwhite,blue

# Prompt color
set promptcolor lightwhite,green

# Status bar color
set statuscolor brightwhite,green

# Error color
set errorcolor brightwhite,red

# =============================================================================
# EDITING
# =============================================================================

# Enable word bounds for word completion
set wordbounds

# Enable smart home key
set smarthome

# Enable zap (delete selected text on backspace)
set zap

# Enable brackets matching
set brackets ""')>]}

# Enable regexp search
set regexp

# Enable multibuffer
set multibuffer

# Enable view mode
# set view

# Disable help
set nohelp

# =============================================================================
# ADVANCED
# =============================================================================

# Preserve XON/XOFF
set preserve

# Enable suspend (allow Ctrl-Z)
# set suspend is not valid

# Enable restricted mode
# set restricted

# =============================================================================
# MACROS & SHORTCUTS
# =============================================================================

# Enable key bindings
# bind ^W writeout main
# bind ^Q exit main
# bind ^S savefile main

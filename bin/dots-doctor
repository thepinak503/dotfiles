#!/usr/bin/env bash
set -euo pipefail
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.local/share/dotfiles}"
DOTFILES_STATE_DIR="${DOTFILES_STATE_DIR:-$HOME/.local/share/dotfiles}"
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; PURPLE='\033[0;35m'; BOLD='\033[1m'; NC='\033[0m'

AUTO_FIX=false
for arg in "$@"; do
    [ "$arg" = "--fix" ] || [ "$arg" = "-f" ] && AUTO_FIX=true
    [ "$arg" = "--help" ] || [ "$arg" = "-h" ] && { echo "Usage: dots doctor [--fix]"; exit 0; }
done

LOG_FILE="$DOTFILES_STATE_DIR/logs/doctor.log"
mkdir -p "$(dirname "$LOG_FILE")"

SCORE=100
DEDUCTIONS=""

deduct() {
    local pts="$1" reason="$2"
    SCORE=$((SCORE - pts))
    DEDUCTIONS="$DEDUCTIONS\n    -${pts}pts  $reason"
}

grade() {
    if [ "$SCORE" -ge 90 ]; then echo "A"
    elif [ "$SCORE" -ge 80 ]; then echo "B"
    elif [ "$SCORE" -ge 70 ]; then echo "C"
    elif [ "$SCORE" -ge 60 ]; then echo "D"
    else echo "F"; fi
}

fix_symlink() {
    local target="$1" link="$2"
    if [ -L "$link" ] && [ ! -e "$link" ]; then
        echo -e "    ${YELLOW}Broken symlink: $link -> $(readlink "$link")${NC}"
        if [ "$AUTO_FIX" = true ]; then
            rm -f "$link"
            ln -sf "$target" "$link" 2>/dev/null && echo -e "    ${GREEN}Fixed: relinked $link${NC}" || echo -e "    ${RED}Failed to fix $link${NC}"
        fi
    fi
}

check_symlink() {
    local target="$1" link="$2" label="$3"
    if [ -L "$link" ]; then
        local current
        current=$(readlink "$link" 2>/dev/null || echo "")
        if [ "$current" = "$target" ]; then
            echo -e "  ${GREEN}✓${NC} $label — linked correctly"
            return 0
        else
            echo -e "  ${YELLOW}⚠${NC} $label — points to $current (expected $target)"
            deduct 2 "$label symlink points wrong"
            [ "$AUTO_FIX" = true ] && ln -sf "$target" "$link" 2>/dev/null && echo -e "    ${GREEN}Fixed${NC}"
            return 1
        fi
    elif [ -e "$link" ]; then
        echo -e "  ${YELLOW}⚠${NC} $label — real file, not a symlink"
        deduct 1 "$label is a real file, not symlink"
        return 1
    else
        echo -e "  ${RED}✗${NC} $label — missing"
        deduct 3 "$label missing"
        return 1
    fi
}

echo -e ""
echo -e "${CYAN}  ┌──────────────────────────────────────────┐${NC}"
echo -e "${CYAN}  │        DOTS DOCTOR ${BOLD}v2.0${CYAN}                │${NC}"
echo -e "${CYAN}  │  Diagnostic + Auto-Repair               │${NC}"
echo -e "${CYAN}  └──────────────────────────────────────────┘${NC}"
echo -e ""
echo -e "  $(date '+%Y-%m-%d %H:%M:%S')"
[ "$AUTO_FIX" = true ] && echo -e "  ${YELLOW}Auto-fix mode enabled${NC}"
echo -e ""

{
    echo "=== DOTS DOCTOR $(date '+%Y-%m-%d %H:%M:%S') ==="
    echo "AUTO_FIX=$AUTO_FIX"
} >> "$LOG_FILE"

# ── 1. DOTFILES DIRECTORY ──
echo -e "${BOLD}  📁 Dotfiles Directory${NC}"
if [ -d "$DOTFILES_DIR" ]; then
    echo -e "  ${GREEN}✓${NC} Found at $DOTFILES_DIR"
    echo "DIRECTORY: OK" >> "$LOG_FILE"
else
    echo -e "  ${RED}✗${NC} Not found at $DOTFILES_DIR"
    deduct 10 "Dotfiles directory missing"
    echo "DIRECTORY: MISSING" >> "$LOG_FILE"
fi

# ── 2. GIT INTEGRITY ──
echo -e "\n${BOLD}  🔧 Git Integrity${NC}"
if [ -d "$DOTFILES_DIR/.git" ]; then
    echo -e "  ${GREEN}✓${NC} Git repository"
    if git -C "$DOTFILES_DIR" diff --quiet HEAD 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Clean working tree"
    else
        UNCOMMITTED=$(git -C "$DOTFILES_DIR" status --porcelain 2>/dev/null | wc -l)
        echo -e "  ${YELLOW}⚠${NC} $UNCOMMITTED uncommitted change(s)"
        deduct 2 "Uncommitted changes ($UNCOMMITTED files)"
    fi
else
    echo -e "  ${RED}✗${NC} Not a git repository"
    deduct 5 "Not a git repository"
fi

# ── 3. CORE TOOLS ──
echo -e "\n${BOLD}  🛠️  Core Tools${NC}"
CORE_TOOLS=(
    "git:git:required"
    "curl:curl:required"
    "fzf:fzf:required"
    "rg:ripgrep:required"
    "bat:bat:required"
    "eza:eza:recommended"
    "fd:fd:recommended"
    "starship:starship:recommended"
    "zoxide:zoxide:recommended"
)
MISSING_TOOLS=""
for entry in "${CORE_TOOLS[@]}"; do
    IFS=':' read -r bin pkg importance <<< "$entry"
    if command -v "$bin" >/dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} $bin"
    else
        if [ "$importance" = "required" ]; then
            echo -e "  ${RED}✗${NC} $bin ($pkg) — ${BOLD}REQUIRED${NC}"
            deduct 5 "Missing required tool: $bin"
        else
            echo -e "  ${YELLOW}⚠${NC} $bin ($pkg) — recommended"
            deduct 2 "Missing recommended tool: $bin"
        fi
        MISSING_TOOLS="$MISSING_TOOLS $bin"
    fi
done

# ── 4. BROKEN SYMLINKS ──
echo -e "\n${BOLD}  🔗 Config Symlinks${NC}"
fix_symlink "$DOTFILES_DIR/shells/bash/.bashrc" "$HOME/.bashrc"
fix_symlink "$DOTFILES_DIR/shells/zsh/.zshrc" "$HOME/.zshrc"
fix_symlink "$DOTFILES_DIR/shells/fish/config.fish" "$HOME/.config/fish/config.fish"
fix_symlink "$DOTFILES_DIR/core/.profile" "$HOME/.profile"
fix_symlink "$DOTFILES_DIR/apps/git/gitconfig" "$HOME/.gitconfig"
fix_symlink "$DOTFILES_DIR/apps/tmux/tmux.conf" "$HOME/.tmux.conf"

check_symlink "$DOTFILES_DIR/shells/bash/.bashrc" "$HOME/.bashrc" ".bashrc"
check_symlink "$DOTFILES_DIR/shells/zsh/.zshrc" "$HOME/.zshrc" ".zshrc"
check_symlink "$DOTFILES_DIR/core/.profile" "$HOME/.profile" ".profile"
check_symlink "$DOTFILES_DIR/apps/git/gitconfig" "$HOME/.gitconfig" ".gitconfig"

# ── 5. HYPRLAND CONFIG ──
if [ -d "$DOTFILES_DIR/hypr" ]; then
    echo -e "\n${BOLD}  🖥️  Hyprland Config${NC}"
    if command -v hyprctl >/dev/null 2>&1; then
        HVER=$(hyprctl version 2>/dev/null | head -1 | grep -oP 'v\S+' || echo "version unknown")
        echo -e "  ${GREEN}✓${NC} Hyprland is running ($HVER)"
    fi
    for conf in monitors input decor animations windowrules workspaces keybinds autostart; do
        if [ -f "$DOTFILES_DIR/hypr/configs/$conf.conf" ]; then
            echo -e "  ${GREEN}✓${NC} hypr/configs/$conf.conf"
        else
            echo -e "  ${RED}✗${NC} hypr/configs/$conf.conf — missing"
            deduct 2 "Missing Hyprland config: $conf.conf"
        fi
    done
fi

# ── 6. WAYBAR ──
if [ -d "$DOTFILES_DIR/waybar" ]; then
    echo -e "\n${BOLD}  📊 Waybar${NC}"
    if pgrep -x waybar >/dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} Waybar running"
    else
        echo -e "  ${YELLOW}⚠${NC} Waybar not running"
        deduct 1 "Waybar not running"
    fi
    [ -f "$DOTFILES_DIR/waybar/config.jsonc" ] && echo -e "  ${GREEN}✓${NC} config.jsonc" || { echo -e "  ${RED}✗${NC} config.jsonc missing"; deduct 2 "Waybar config missing"; }
    [ -f "$DOTFILES_DIR/waybar/style.css" ] && echo -e "  ${GREEN}✓${NC} style.css" || { echo -e "  ${RED}✗${NC} style.css missing"; deduct 2 "Waybar CSS missing"; }
fi

# ── 7. SHELL SYNTAX CHECK ──
echo -e "\n${BOLD}  📝 Shell Syntax${NC}"
for f in "$DOTFILES_DIR/core/aliases.sh" "$DOTFILES_DIR/core/functions.sh" "$DOTFILES_DIR/core/universal.sh"; do
    if [ -f "$f" ]; then
        if bash -n "$f" 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} $(basename "$f") — valid syntax"
        else
            SYNTAX_ERR=$(bash -n "$f" 2>&1 || true)
            echo -e "  ${RED}✗${NC} $(basename "$f") — syntax error"
            echo "    $SYNTAX_ERR"
            deduct 3 "Syntax error in $(basename "$f")"
        fi
    fi
done

# ── 8. LOG FILES ──
echo -e "\n${BOLD}  📋 Log Files${NC}"
STORAGE=$(du -sh "$DOTFILES_STATE_DIR" 2>/dev/null | cut -f1 || echo "0K")
echo -e "  ${GREEN}✓${NC} State directory: $STORAGE"
for f in "$DOTFILES_STATE_DIR"/logs/*.log; do
    [ -f "$f" ] || continue
    FSIZE=$(stat -c%s "$f" 2>/dev/null || echo "0")
    if [ "$FSIZE" -gt 10485760 ]; then
        FNAME=$(basename "$f")
        echo -e "  ${YELLOW}⚠${NC} $FNAME is large ($(du -h "$f" | cut -f1))"
        deduct 1 "Large log file: $FNAME"
    fi
done

# ── 9. PACKAGE MANAGER ──
echo -e "\n${BOLD}  📦 Package Manager${NC}"
if command -v brew >/dev/null 2>&1; then echo -e "  ${GREEN}✓${NC} brew"
elif command -v pacman >/dev/null 2>&1; then echo -e "  ${GREEN}✓${NC} pacman"
elif command -v apt-get >/dev/null 2>&1; then echo -e "  ${GREEN}✓${NC} apt"
elif command -v dnf >/dev/null 2>&1; then echo -e "  ${GREEN}✓${NC} dnf"
elif command -v zypper >/dev/null 2>&1; then echo -e "  ${GREEN}✓${NC} zypper"
else echo -e "  ${YELLOW}⚠${NC} Unknown package manager"; deduct 1 "Unknown package manager"; fi

# ── 10. AUTO-FIX MISSING TOOLS ──
if [ -n "$MISSING_TOOLS" ] && [ "$AUTO_FIX" = true ]; then
    echo -e "\n${BOLD}  🔧 Auto-Fixing Missing Tools${NC}"
    PM=""
    command -v pacman >/dev/null 2>&1 && PM="pacman"
    command -v apt-get >/dev/null 2>&1 && PM="apt"
    command -v dnf >/dev/null 2>&1 && PM="dnf"
    command -v brew >/dev/null 2>&1 && PM="brew"
    if [ -n "$PM" ]; then
        for tool in $MISSING_TOOLS; do
            PKG="$tool"
            case "$tool" in
                rg) PKG="ripgrep" ;;
                fd) [ "$PM" = "apt" ] && PKG="fd-find" || PKG="fd" ;;
                starship) [ "$PM" != "brew" ] && [ "$PM" != "pacman" ] && PKG="" ;;
                zoxide) [ "$PM" != "brew" ] && [ "$PM" != "pacman" ] && PKG="" ;;
            esac
            if [ -n "$PKG" ]; then
                echo -e "    Installing $tool..."
                case "$PM" in
                    pacman) sudo pacman -S --noconfirm "$PKG" >/dev/null 2>&1 && echo -e "    ${GREEN}Installed $tool${NC}" || echo -e "    ${YELLOW}Failed to install $tool${NC}" ;;
                    apt)    sudo apt-get install -y "$PKG" >/dev/null 2>&1 && echo -e "    ${GREEN}Installed $tool${NC}" || echo -e "    ${YELLOW}Failed to install $tool${NC}" ;;
                    dnf)    sudo dnf install -y "$PKG" >/dev/null 2>&1 && echo -e "    ${GREEN}Installed $tool${NC}" || echo -e "    ${YELLOW}Failed to install $tool${NC}" ;;
                    brew)   brew install "$PKG" >/dev/null 2>&1 && echo -e "    ${GREEN}Installed $tool${NC}" || echo -e "    ${YELLOW}Failed to install $tool${NC}" ;;
                esac
            fi
        done
    fi
fi

# ── 11. WAYLAND CHECK ──
if [ "$(uname -s)" = "Linux" ]; then
    echo -e "\n${BOLD}  🎨 Display Server${NC}"
    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        echo -e "  ${GREEN}✓${NC} Running Wayland ($WAYLAND_DISPLAY)"
    elif [ -n "${DISPLAY:-}" ]; then
        echo -e "  ${YELLOW}⚠${NC} Running X11 ($DISPLAY) — dots optimized for Wayland"
        deduct 1 "Running X11 instead of Wayland"
    else
        echo -e "  ${YELLOW}⚠${NC} No display detected (TTY?)"
    fi
fi

# ── FINAL SCORE ──
MAX_SCORE=100
[ "$SCORE" -lt 0 ] && SCORE=0
LETTER=$(grade)

echo -e ""
echo -e "${CYAN}  ┌──────────────────────────────────────────┐${NC}"
echo -e "${CYAN}  │${NC}         ${BOLD}DOTS HEALTH SCORE${NC}                ${CYAN}│${NC}"
echo -e "${CYAN}  │${NC}                                           ${CYAN}│${NC}"
printf "  │${NC}           %s %3d/%-3d %s               ${CYAN}│${NC}\n" "$PURPLE" "$SCORE" "$MAX_SCORE" "$NC"
printf "  │${NC}           Grade: ${BOLD}%s${NC}                      ${CYAN}│${NC}\n" "$LETTER"
echo -e "${CYAN}  │${NC}                                           ${CYAN}│${NC}"
if [ -n "$DEDUCTIONS" ]; then
    echo -e "${CYAN}  │${NC}  ${BOLD}Deductions:${NC}                        ${CYAN}│${NC}"
    echo -e "$DEDUCTIONS" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        printf "  │${NC}  %-42s${CYAN}│${NC}\n" "$line"
    done
fi
echo -e "${CYAN}  │${NC}                                           ${CYAN}│${NC}"
if [ "$SCORE" -ge 90 ]; then
    echo -e "${CYAN}  │${NC}  ${GREEN}✓ Excellent — your dotfiles are healthy    ${NC}${CYAN}│${NC}"
elif [ "$SCORE" -ge 70 ]; then
    echo -e "${CYAN}  │${NC}  ${YELLOW}⚠ Good — a few things to clean up         ${NC}${CYAN}│${NC}"
elif [ "$SCORE" -ge 50 ]; then
    echo -e "${CYAN}  │${NC}  ${RED}✗ Needs work — run with --fix             ${NC}${CYAN}│${NC}"
else
    echo -e "${CYAN}  │${NC}  ${RED}✗ Critical — re-run installer             ${NC}${CYAN}│${NC}"
fi
echo -e "${CYAN}  │${NC}                                           ${CYAN}│${NC}"
if [ "$AUTO_FIX" = false ] && [ "$SCORE" -lt 100 ]; then
    echo -e "${CYAN}  │${NC}  ${YELLOW}Tip:${NC} Run ${BOLD}dots doctor --fix${NC} to auto-repair  ${CYAN}│${NC}"
fi
echo -e "${CYAN}  └──────────────────────────────────────────┘${NC}"
echo ""

{
    echo "SCORE=$SCORE/$MAX_SCORE"
    echo "GRADE=$LETTER"
    echo "DEDUCTIONS:"
    echo -e "$DEDUCTIONS"
    echo "=== END ==="
} >> "$LOG_FILE"
